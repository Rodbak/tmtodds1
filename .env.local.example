# Copy this file to .env.local and fill in real values.
# .env.local is already git-ignored by create-next-app's default .gitignore.

# Supabase -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
# Service role key: full access, bypasses RLS. Server-only -- never
# add the NEXT_PUBLIC_ prefix to this one.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Paystack -> Settings -> API Keys & Webhooks
# Use the pk_test_ / sk_test_ pair until you're ready to go live.
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Used to build the redirect URL Paystack sends people back to after
# paying, and in a couple of absolute links. Set this to your real
# domain in production (e.g. https://tmtodds.com).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Google Analytics -> Admin -> Data Streams -> your web stream -> Measurement ID (starts with G-)
# Leave blank to run without analytics; the app works either way.
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Live scores -> api-football's direct API at dashboard.api-football.com
# (free tier: ~100 requests/day). Server-only. Leave blank to run
# without live scores; picks just never show a live badge.
SPORTS_API_KEY=
